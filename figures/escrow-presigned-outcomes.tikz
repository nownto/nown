\begin{tikzpicture}[>={Stealth[length=5pt]}, box/.style={draw=ink, rounded corners=1pt, minimum height=22pt, minimum width=2.8cm, font=\small, align=center, inner sep=4pt}, outcome/.style={draw=ink, dashed, rounded corners=1pt, minimum height=22pt, minimum width=2.4cm, font=\small}, flow/.style={->, ink, thick}] \node[box] (escrow) at (0,0) {2 of 2 escrow\\[1pt]{\footnotesize\color{muted}price + both deposits}}; \node[outcome] (buyer) at (6.4,1.7) {buyer paid}; \node[outcome] (seller) at (6.4,0) {seller paid}; \node[outcome] (returned) at (6.4,-1.7) {funds returned}; \draw[flow] (escrow.east) -- (buyer.west); \draw[flow] (escrow.east) -- (seller.west); \draw[flow] (escrow.east) -- (returned.west); \node[box, minimum width=1.9cm] (quorum) at (0,-2.7) {quorum}; \node[anchor=west, xshift=6pt, font=\footnotesize, text=muted] at (quorum.east) {holds no key}; \draw[->, bronze, thick] (quorum.north) -- (3.4,-0.2); \node[font=\small, text=bronze] at (2.2,-1.35) {one signature}; \end{tikzpicture}